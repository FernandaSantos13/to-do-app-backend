{
	"dependencies": {
		"@prisma/client": "^6.7.0",
		"cors": "^2.8.5",
		"express": "^5.1.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"nodemon": "^3.1.9",
		"prisma": "^6.7.0",
		"ts-node-dev": "^2.0.0",
		"tsx": "^4.19.3"
	},
	"scripts": {
		"dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
